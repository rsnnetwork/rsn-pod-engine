{
  "name": "rsn-platform",
  "version": "1.0.0",
  "private": true,
  "description": "RSN Pod Engine - Structured connection operating system",
  "workspaces": [
    "shared",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "build": "npm run build --workspace=shared && npm run build --workspace=server",
    "build:shared": "npm run build --workspace=shared",
    "build:server": "npm run build --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "lint": "npm run lint --workspace=shared && npm run lint --workspace=server",
    "test": "npm run test --workspace=server",
    "clean": "rimraf shared/dist server/dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
