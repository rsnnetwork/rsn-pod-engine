{
  "name": "rsn-platform",
  "version": "1.0.0",
  "private": true,
  "description": "RSN Pod Engine - Structured connection operating system",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "build:shared": "npm run build --workspace=shared",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "lint": "npm run lint --workspace=shared && npm run lint --workspace=server && npm run lint:realtime",
    "lint:realtime": "node scripts/check-realtime-entities.js",
    "test": "npm run test --workspace=server",
    "clean": "rimraf shared/dist server/dist",
    "prepare": "git config core.hooksPath .githooks"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
