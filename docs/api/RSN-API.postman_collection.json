{
  "info": {
    "name": "RSN Pod Engine – Full API",
    "description": "Complete Postman collection for RSN Platform Milestone 1.\n\nQuick Start:\n1. Run 'Request Magic Link' with any email\n2. Copy token from server console log\n3. Run 'Verify Magic Link' — access token auto-saves\n4. All other requests auto-use the saved token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "podId", "value": "", "type": "string" },
    { "key": "sessionId", "value": "", "type": "string" },
    { "key": "inviteCode", "value": "", "type": "string" },
    { "key": "inviteId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "matchId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🟢 Health Check",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Request Magic Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Magic link requested', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "console.log('\\n✅ Magic link sent! Check your SERVER CONSOLE for the token.');",
                  "console.log('Look for: magicLinkUrl with ?token=<64-char-hex>');",
                  "console.log('Copy that hex token and paste it into the Verify request body.\\n');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/magic-link", "host": ["{{baseUrl}}"], "path": ["api", "auth", "magic-link"] }
          }
        },
        {
          "name": "2. Verify Magic Link ⬅️ Paste token here",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    console.log('✅ accessToken saved to collection variables');",
                  "  }",
                  "  if (res.data.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "    console.log('✅ refreshToken saved to collection variables');",
                  "  }",
                  "}",
                  "pm.test('Token verified & JWT received', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "  pm.expect(res.data.accessToken).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_64_CHAR_HEX_TOKEN_HERE\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/verify", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify"] }
          }
        },
        {
          "name": "3. Get Current Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Session retrieved', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "if (res.data && res.data.user && res.data.user.id) {",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/session", "host": ["{{baseUrl}}"], "path": ["api", "auth", "session"] }
          }
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  if (res.data.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('✅ Tokens refreshed and saved');",
                  "}",
                  "pm.test('Token refreshed', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
