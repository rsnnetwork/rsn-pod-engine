#!/bin/bash
# ─── RSN Secret Guard — Pre-Commit Hook ──────────────────────────────────────
# Blocks commits that contain real secrets in .env.example files or source code.
# This hook runs automatically before every git commit.

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔒 RSN Secret Guard: scanning staged files...${NC}"

FAILED=0

# ─── 1. Check .env.example files for real secret values ──────────────────────
# These keys must be EMPTY or contain only placeholder text in .env.example
SENSITIVE_KEYS=(
  "DATABASE_URL"
  "REDIS_URL"
  "JWT_SECRET"
  "MAGIC_LINK_SECRET"
  "RESEND_API_KEY"
  "SMTP_USER"
  "SMTP_PASS"
  "LIVEKIT_API_KEY"
  "LIVEKIT_API_SECRET"
  "STRIPE_SECRET_KEY"
  "STRIPE_WEBHOOK_SECRET"
)

# Allowed placeholder values (not real secrets)
PLACEHOLDER_PATTERN="^(|your-.*|change-.*|replace-.*|xxx.*|placeholder.*|localhost.*|redis://localhost.*|postgres://(rsn_dev|postgres|user):.*@localhost.*)$"

for example_file in $(git diff --cached --name-only | grep '\.env\.example$'); do
  echo "  Checking $example_file..."
  FILE_CONTENT=$(git show ":$example_file" 2>/dev/null)
  if [ -z "$FILE_CONTENT" ]; then
    continue
  fi

  for key in "${SENSITIVE_KEYS[@]}"; do
    VALUE=$(echo "$FILE_CONTENT" | grep -E "^${key}=" | head -1 | sed "s/^${key}=//")
    # Skip if key not present or value is empty
    if [ -z "$VALUE" ]; then
      continue
    fi
    # Check if value looks like a real secret (not a placeholder)
    if ! echo "$VALUE" | grep -qiE "$PLACEHOLDER_PATTERN"; then
      echo -e "${RED}  ✖ BLOCKED: $example_file contains a real value for $key${NC}"
      echo -e "    Value: ${VALUE:0:8}... (truncated)"
      echo -e "    Fix: set ${key}= (empty) or use a placeholder like 'your-${key,,}-here'"
      FAILED=1
    fi
  done
done

# ─── 2. Scan ALL staged files for common secret patterns ─────────────────────
# Catches accidentally hardcoded keys anywhere in the codebase
SECRET_PATTERNS=(
  # AWS
  'AKIA[0-9A-Z]{16}'
  # Stripe live keys
  'sk_live_[0-9a-zA-Z]{24,}'
  'pk_live_[0-9a-zA-Z]{24,}'
  # GitHub tokens
  'ghp_[0-9a-zA-Z]{36}'
  'github_pat_[0-9a-zA-Z_]{80,}'
  # Resend
  're_[0-9a-zA-Z]{20,}'
  # LiveKit (API keys are typically short, but secrets are long base64)
  'API[a-zA-Z0-9]{20,}'
  # Generic long base64 secrets after known keys
  '(SECRET|PASSWORD|TOKEN|API_KEY)=['\''"]?[A-Za-z0-9+/=]{32,}'
  # Private keys
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'
  # Slack tokens
  'xox[bpors]-[0-9a-zA-Z-]{10,}'
)

# Files to skip (binary, lock files, etc.)
SKIP_PATTERN='\.(lock|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|pdf)$|package-lock\.json$|yarn\.lock$|pnpm-lock\.yaml$'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -vE "$SKIP_PATTERN")

for file in $STAGED_FILES; do
  CONTENT=$(git show ":$file" 2>/dev/null)
  if [ -z "$CONTENT" ]; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    # `grep -- -E ...` doesn't work when -E precedes the dash-pattern arg;
    # `grep -nE -- "$pattern"` stops option parsing so leading `-` in patterns
    # like `-----BEGIN ... PRIVATE KEY-----` doesn't get treated as a flag.
    MATCH=$(echo "$CONTENT" | grep -nE -- "$pattern" | head -3)
    if [ -n "$MATCH" ]; then
      # Skip .env.example placeholder lines (already handled above)
      if echo "$file" | grep -q '\.env\.example$'; then
        continue
      fi
      echo -e "${RED}  ✖ BLOCKED: potential secret in $file${NC}"
      echo "$MATCH" | while read -r line; do
        LINENUM=$(echo "$line" | cut -d: -f1)
        echo -e "    Line $LINENUM matches pattern: $pattern"
      done
      FAILED=1
    fi
  done
done

# ─── 3. Block real .env files from ever being committed ──────────────────────
ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)\.env$|(^|/)\.env\.(local|development|test|production)$|(^|/)\.env\.[^.]+\.local$')
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}  ✖ BLOCKED: real .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES" | while read -r f; do
    echo -e "    $f"
  done
  echo -e "    Fix: git reset HEAD <file> to unstage"
  FAILED=1
fi

# ─── 4. Block Render env dumps (JSON format) from being committed ────────────
# `render env list ... --output json` produces an array of {envVar:{key,value}}
# objects that bypass the KEY=value scanner in section 2. Block by filename AND
# by content shape so they can't sneak in under a different name.
RENDER_ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)render-env([._-].*)?\.json$')
if [ -n "$RENDER_ENV_FILES" ]; then
  echo -e "${RED}  ✖ BLOCKED: Render env dump file(s) staged for commit:${NC}"
  echo "$RENDER_ENV_FILES" | while read -r f; do
    echo -e "    $f"
  done
  echo -e "    Fix: git reset HEAD <file> to unstage. These files contain prod secrets."
  FAILED=1
fi

# Content shape: any staged file containing the Render-dump signature.
for file in $STAGED_FILES; do
  CONTENT=$(git show ":$file" 2>/dev/null)
  if [ -z "$CONTENT" ]; then
    continue
  fi
  # Match the {"envVar":{"key":"...","value":"..."}} shape for sensitive keys.
  if echo "$CONTENT" | grep -qE '"envVar"[[:space:]]*:[[:space:]]*\{[[:space:]]*"key"[[:space:]]*:[[:space:]]*"(JWT_SECRET|DATABASE_URL|REDIS_URL|MAGIC_LINK_SECRET|RESEND_API_KEY|LIVEKIT_API_SECRET|STRIPE_SECRET_KEY|GOOGLE_CLIENT_SECRET|SMTP_PASS)"'; then
    echo -e "${RED}  ✖ BLOCKED: $file contains a Render env dump with sensitive keys${NC}"
    echo -e "    Looks like the JSON output of 'render env list'. These dumps contain prod secrets."
    echo -e "    Fix: git reset HEAD $file to unstage, then add the file pattern to .gitignore."
    FAILED=1
  fi
done

# ─── Result ──────────────────────────────────────────────────────────────────
if [ $FAILED -ne 0 ]; then
  echo ""
  echo -e "${RED}✖ Commit blocked by RSN Secret Guard.${NC}"
  echo -e "  Fix the issues above, then try again."
  echo -e "  If this is a false positive, use: git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}✔ RSN Secret Guard: all clear — no secrets detected.${NC}"
exit 0
