#!/bin/bash
# в”Ђв”Ђв”Ђ RSN Secret Guard вЂ” Pre-Commit Hook в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Blocks commits that contain real secrets in .env.example files or source code.
# This hook runs automatically before every git commit.

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${YELLOW}рџ”’ RSN Secret Guard: scanning staged files...${NC}"

FAILED=0

# в”Ђв”Ђв”Ђ 1. Check .env.example files for real secret values в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# These keys must be EMPTY or contain only placeholder text in .env.example
SENSITIVE_KEYS=(
  "DATABASE_URL"
  "REDIS_URL"
  "JWT_SECRET"
  "MAGIC_LINK_SECRET"
  "RESEND_API_KEY"
  "SMTP_USER"
  "SMTP_PASS"
  "LIVEKIT_API_KEY"
  "LIVEKIT_API_SECRET"
  "STRIPE_SECRET_KEY"
  "STRIPE_WEBHOOK_SECRET"
)

# Allowed placeholder values (not real secrets)
PLACEHOLDER_PATTERN="^(|your-.*|change-.*|replace-.*|xxx.*|placeholder.*|localhost.*|redis://localhost.*|postgres://(rsn_dev|postgres|user):.*@localhost.*)$"

for example_file in $(git diff --cached --name-only | grep '\.env\.example$'); do
  echo "  Checking $example_file..."
  FILE_CONTENT=$(git show ":$example_file" 2>/dev/null)
  if [ -z "$FILE_CONTENT" ]; then
    continue
  fi

  for key in "${SENSITIVE_KEYS[@]}"; do
    VALUE=$(echo "$FILE_CONTENT" | grep -E "^${key}=" | head -1 | sed "s/^${key}=//")
    # Skip if key not present or value is empty
    if [ -z "$VALUE" ]; then
      continue
    fi
    # Check if value looks like a real secret (not a placeholder)
    if ! echo "$VALUE" | grep -qiE "$PLACEHOLDER_PATTERN"; then
      echo -e "${RED}  вњ– BLOCKED: $example_file contains a real value for $key${NC}"
      echo -e "    Value: ${VALUE:0:8}... (truncated)"
      echo -e "    Fix: set ${key}= (empty) or use a placeholder like 'your-${key,,}-here'"
      FAILED=1
    fi
  done
done

# в”Ђв”Ђв”Ђ 2. Scan ALL staged files for common secret patterns в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Catches accidentally hardcoded keys anywhere in the codebase
SECRET_PATTERNS=(
  # AWS
  'AKIA[0-9A-Z]{16}'
  # Stripe live keys
  'sk_live_[0-9a-zA-Z]{24,}'
  'pk_live_[0-9a-zA-Z]{24,}'
  # GitHub tokens
  'ghp_[0-9a-zA-Z]{36}'
  'github_pat_[0-9a-zA-Z_]{80,}'
  # Resend
  're_[0-9a-zA-Z]{20,}'
  # LiveKit (API keys are typically short, but secrets are long base64)
  'API[a-zA-Z0-9]{20,}'
  # Generic long base64 secrets after known keys
  '(SECRET|PASSWORD|TOKEN|API_KEY)=['\''"]?[A-Za-z0-9+/=]{32,}'
  # Private keys
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'
  # Slack tokens
  'xox[bpors]-[0-9a-zA-Z-]{10,}'
)

# Files to skip (binary, lock files, etc.)
SKIP_PATTERN='\.(lock|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|pdf)$|package-lock\.json$|yarn\.lock$|pnpm-lock\.yaml$'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -vE "$SKIP_PATTERN")

for file in $STAGED_FILES; do
  CONTENT=$(git show ":$file" 2>/dev/null)
  if [ -z "$CONTENT" ]; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCH=$(echo "$CONTENT" | grep -nE "$pattern" | head -3)
    if [ -n "$MATCH" ]; then
      # Skip .env.example placeholder lines (already handled above)
      if echo "$file" | grep -q '\.env\.example$'; then
        continue
      fi
      echo -e "${RED}  вњ– BLOCKED: potential secret in $file${NC}"
      echo "$MATCH" | while read -r line; do
        LINENUM=$(echo "$line" | cut -d: -f1)
        echo -e "    Line $LINENUM matches pattern: $pattern"
      done
      FAILED=1
    fi
  done
done

# в”Ђв”Ђв”Ђ 3. Block real .env files from ever being committed в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)\.env$|(^|/)\.env\.(local|development|test|production)$|(^|/)\.env\.[^.]+\.local$')
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}  вњ– BLOCKED: real .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES" | while read -r f; do
    echo -e "    $f"
  done
  echo -e "    Fix: git reset HEAD <file> to unstage"
  FAILED=1
fi

# в”Ђв”Ђв”Ђ Result в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ $FAILED -ne 0 ]; then
  echo ""
  echo -e "${RED}вњ– Commit blocked by RSN Secret Guard.${NC}"
  echo -e "  Fix the issues above, then try again."
  echo -e "  If this is a false positive, use: git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}вњ” RSN Secret Guard: all clear вЂ” no secrets detected.${NC}"
exit 0
