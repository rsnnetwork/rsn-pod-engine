# RSN Client Environment Variables
# In development, the Vite proxy handles /api → localhost:3001
# In production, set these to your deployed backend URL

# API base URL (include /api)
VITE_API_URL=/api

# Server URL for Socket.IO (just the origin, no path)
VITE_SERVER_URL=/

VITE_SENTRY_DSN=

# Cloudinary direct-upload (Feature 19 — DM image attachments).
# Cloud name is the public identifier from your Cloudinary dashboard.
# Upload preset must be configured as Unsigned in Cloudinary settings
# with allowed_formats=jpg,png,webp,gif and max_file_size=10485760.
# Leave both blank to ship without image upload — the picker is hidden
# when either is missing.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
