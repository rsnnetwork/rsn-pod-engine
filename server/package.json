{
  "name": "@rsn/server",
  "version": "1.0.0",
  "private": true,
  "description": "RSN Pod Engine - Backend Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');const s=p.join(__dirname,'src/db/migrations');const d=p.join(__dirname,'dist/db/migrations');fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@rsn/shared": "1.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.0.0",
    "nanoid": "^3.3.7",
    "nodemailer": "^6.9.0",
    "pg": "^8.12.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "resend": "^6.9.3",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
