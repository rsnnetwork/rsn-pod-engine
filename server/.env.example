# ─── RSN Server Environment Variables ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgres://rsn_dev:rsn_dev_password@localhost:5432/rsn_dev
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Magic Link
MAGIC_LINK_SECRET=your-magic-link-secret-change-in-production
MAGIC_LINK_EXPIRY_MINUTES=15

# Email (Resend recommended)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=noreply@rsn.network
# Legacy SMTP (if not using Resend)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# Stripe (Billing readiness)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

SENTRY_DSN=
